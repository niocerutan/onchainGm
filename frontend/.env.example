# Copy this to .env.local and fill in your values

# Get a free WalletConnect Project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Set this after deploying the GM contract (from: npm run deploy:testnet)
VITE_GM_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
